# Database
DATABASE_URL=postgresql://orchestrator:orchestrator@localhost:5433/orchestrator

# Anthropic (for agents)
ANTHROPIC_API_KEY=

# Dispatcher
POLL_INTERVAL=60000

# Telegram (optional — configure via Extensions UI instead)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Supabase Branching (per-project, w .env projektu)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# GitHub (for draft PRs — per-project, w .env projektu)
# GITHUB_TOKEN=
